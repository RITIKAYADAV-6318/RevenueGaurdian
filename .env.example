# ==============================================================================
# Revenue Guardian - Environment Configuration Template
# ==============================================================================
# Copy this file to '.env' and populate with your credentials.
# Do NOT commit the '.env' file containing active secrets to source control.

# ------------------------------------------------------------------------------
# 1. Google Gemini & AI Configuration
# ------------------------------------------------------------------------------
# Get your API key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Model options: gemini-2.0-flash (default), gemini-1.5-pro, etc.
GEMINI_MODEL_NAME=your_gemini_model_name_here
GEMINI_TEMPERATURE=your_gemini_temperature_here

# ------------------------------------------------------------------------------
# 2. Database Configuration
# ------------------------------------------------------------------------------
# For local testing, SQLite is used automatically.
# Format: sqlite:///filename.db or postgresql://user:password@host:port/dbname
DATABASE_URL=your_database_url_here

# ------------------------------------------------------------------------------
# 3. Security & Authentication (JWT)
# ------------------------------------------------------------------------------
# Generate a secure key in your terminal using: openssl rand -hex 32
JWT_SECRET_KEY=generate_a_secure_hex_key_and_paste_here
JWT_ALGORITHM=your_jwt_algorithm_here
ACCESS_TOKEN_EXPIRE_MINUTES=your_access_token_expire_minutes_here

# ------------------------------------------------------------------------------
# 4. Third-Party Integrations (Optional)
# ------------------------------------------------------------------------------
# Slack Incoming Webhook URL for alerts (e.g., #revops-alerts)
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# Note: Gmail and Calendar APIs use 'credentials.json' and 'token.json' / 'token_calendar.json'
# for OAuth2 authentication and do not require environment variables.
